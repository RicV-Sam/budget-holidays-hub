RewriteEngine On

# Force HTTPS in a single hop while preserving path and query string
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://budgetholidayshub.com%{REQUEST_URI} [R=301,L,NE]

# Consolidate legacy Spain URL
RewriteRule ^guides/spain-budget-holidays/?$ https://budgetholidayshub.com/guides/cheap-holidays-spain-from-uk/ [R=301,L,NE]
